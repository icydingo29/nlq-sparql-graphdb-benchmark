<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/geo_ontology_final.owl"
         xmlns="http://example.org/geo_ontology_final.owl#">

<owl:Ontology rdf:about="http://example.org/geo_ontology_final.owl"/>

<owl:ObjectProperty rdf:about="#is_located_in">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Place"/>
        <rdf:Description rdf:about="#Country"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Place"/>
        <rdf:Description rdf:about="#Country"/>
        <rdf:Description rdf:about="#Continent"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
  <owl:inverseOf rdf:resource="#contains"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#contains">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Place"/>
        <rdf:Description rdf:about="#Country"/>
        <rdf:Description rdf:about="#Continent"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Country"/>
        <rdf:Description rdf:about="#Place"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
  <owl:inverseOf rdf:resource="#is_located_in"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_peak_in">
  <rdfs:subPropertyOf rdf:resource="#is_located_in"/>
  <rdfs:domain rdf:resource="#Peak"/>
  <rdfs:range rdf:resource="#Mountain"/>
  <owl:inverseOf rdf:resource="#has_peak"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_peak">
  <rdfs:domain rdf:resource="#Mountain"/>
  <rdfs:range rdf:resource="#Peak"/>
  <owl:inverseOf rdf:resource="#is_peak_in"/>
  <rdfs:subPropertyOf rdf:resource="#contains"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_island_in">
  <rdfs:subPropertyOf rdf:resource="#is_located_in"/>
  <rdfs:domain rdf:resource="#Island"/>
  <rdfs:range rdf:resource="#WaterNaturalLocation"/>
  <owl:inverseOf rdf:resource="#has_island"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_island">
  <rdfs:domain rdf:resource="#WaterNaturalLocation"/>
  <rdfs:range rdf:resource="#Island"/>
  <owl:inverseOf rdf:resource="#is_island_in"/>
  <rdfs:subPropertyOf rdf:resource="#contains"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_border_with">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  <rdfs:domain rdf:resource="#Country"/>
  <rdfs:range rdf:resource="#Country"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_main_religion">
  <rdfs:domain rdf:resource="#Country"/>
  <rdfs:range rdf:resource="#Religion"/>
  <owl:inverseOf rdf:resource="#is_main_religion_in"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_main_religion_in">
  <rdfs:domain rdf:resource="#Religion"/>
  <rdfs:range rdf:resource="#Country"/>
  <owl:inverseOf rdf:resource="#has_main_religion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_form_of_government">
  <rdfs:domain rdf:resource="#Country"/>
  <rdfs:range rdf:resource="#Form_of_Government"/>
  <owl:inverseOf rdf:resource="#is_applied_in"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_applied_in">
  <rdfs:domain rdf:resource="#Form_of_Government"/>
  <rdfs:range rdf:resource="#Country"/>
  <owl:inverseOf rdf:resource="#has_form_of_government"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_architecture">
  <rdfs:domain rdf:resource="#Building"/>
  <rdfs:range rdf:resource="#Architecture"/>
  <owl:inverseOf rdf:resource="#is_architecture_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_architecture_of">
  <rdfs:domain rdf:resource="#Architecture"/>
  <rdfs:range rdf:resource="#Building"/>
  <owl:inverseOf rdf:resource="#has_architecture"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_head_of_state">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Country"/>
  <owl:inverseOf rdf:resource="#has_head_of_state"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_head_of_state">
  <rdfs:domain rdf:resource="#Country"/>
  <rdfs:range rdf:resource="#Person"/>
  <owl:inverseOf rdf:resource="#is_head_of_state"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_mayor_of">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#PopulatedPlace"/>
  <owl:inverseOf rdf:resource="#has_mayor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_mayor">
  <rdfs:domain rdf:resource="#PopulatedPlace"/>
  <rdfs:range rdf:resource="#Person"/>
  <owl:inverseOf rdf:resource="#is_mayor_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_head_of_temple">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Temple"/>
  <owl:inverseOf rdf:resource="#has_head_of_temple"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_head_of_temple">
  <rdfs:domain rdf:resource="#Temple"/>
  <rdfs:range rdf:resource="#Person"/>
  <owl:inverseOf rdf:resource="#is_head_of_temple"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_created_by">
  <rdfs:domain rdf:resource="#Country"/>
  <rdfs:range rdf:resource="#Person"/>
  <owl:inverseOf rdf:resource="#has_created"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_created">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Country"/>
  <owl:inverseOf rdf:resource="#is_created_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_found_by">
  <rdfs:domain rdf:resource="#Continent"/>
  <rdfs:range rdf:resource="#Person"/>
  <owl:inverseOf rdf:resource="#has_found"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_found">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Continent"/>
  <owl:inverseOf rdf:resource="#is_found_by"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#population">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Country"/>
        <rdf:Description rdf:about="#Continent"/>
        <rdf:Description rdf:about="#PopulatedPlace"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#name">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#height">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#LandNaturalLocation"/>
        <rdf:Description rdf:about="#Landmark"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#depth">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WaterNaturalLocation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#is_saltwatered">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WaterNaturalLocation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#is_capital">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#City"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#area">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Place"/>
        <rdf:Description rdf:about="#Country"/>
        <rdf:Description rdf:about="#Continent"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#first_name">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#last_name">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#age">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#construction_date">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Building"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#is_tropical">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Forest"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#period">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Architecture"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#temperature">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Place"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Place">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Continent">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Country">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Religion">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Form_of_Government">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Architecture">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Person">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#PopulatedPlace">
  <rdfs:subClassOf rdf:resource="#Place"/>
</owl:Class>

<owl:Class rdf:about="#Village">
  <rdfs:subClassOf rdf:resource="#PopulatedPlace"/>
</owl:Class>

<owl:Class rdf:about="#City">
  <rdfs:subClassOf rdf:resource="#PopulatedPlace"/>
  <owl:disjointWith rdf:resource="#Village"/>
</owl:Class>

<owl:Class rdf:about="#Landmark">
  <rdfs:subClassOf rdf:resource="#Place"/>
</owl:Class>

<owl:Class rdf:about="#NaturalLandmark">
  <rdfs:subClassOf rdf:resource="#Landmark"/>
</owl:Class>

<owl:Class rdf:about="#CulturalLandmark">
  <rdfs:subClassOf rdf:resource="#Landmark"/>
</owl:Class>

<owl:Class rdf:about="#Building">
  <rdfs:subClassOf rdf:resource="#CulturalLandmark"/>
</owl:Class>

<owl:Class rdf:about="#Castle">
  <rdfs:subClassOf rdf:resource="#Building"/>
</owl:Class>

<owl:Class rdf:about="#Temple">
  <rdfs:subClassOf rdf:resource="#Building"/>
</owl:Class>

<owl:Class rdf:about="#Monastery">
  <rdfs:subClassOf rdf:resource="#Temple"/>
</owl:Class>

<owl:Class rdf:about="#Mosque">
  <rdfs:subClassOf rdf:resource="#Temple"/>
</owl:Class>

<owl:Class rdf:about="#BuddhistTemple">
  <rdfs:subClassOf rdf:resource="#Temple"/>
</owl:Class>

<owl:Class rdf:about="#Church">
  <rdfs:subClassOf rdf:resource="#Temple"/>
</owl:Class>

<owl:Class rdf:about="#NaturalLocation">
  <rdfs:subClassOf rdf:resource="#Place"/>
</owl:Class>

<owl:Class rdf:about="#WaterNaturalLocation">
  <rdfs:subClassOf rdf:resource="#NaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#River">
  <rdfs:subClassOf rdf:resource="#WaterNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#Lake">
  <rdfs:subClassOf rdf:resource="#WaterNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#Sea">
  <rdfs:subClassOf rdf:resource="#WaterNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#Ocean">
  <rdfs:subClassOf rdf:resource="#WaterNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#LandNaturalLocation">
  <rdfs:subClassOf rdf:resource="#NaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#Mountain">
  <rdfs:subClassOf rdf:resource="#LandNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#Peak">
  <rdfs:subClassOf rdf:resource="#LandNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#Volcano">
  <rdfs:subClassOf rdf:resource="#LandNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#Desert">
  <rdfs:subClassOf rdf:resource="#LandNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#Forest">
  <rdfs:subClassOf rdf:resource="#LandNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#Island">
  <rdfs:subClassOf rdf:resource="#LandNaturalLocation"/>
</owl:Class>

<owl:Class rdf:about="#EuropeanCountry">
  <rdfs:subClassOf rdf:resource="#Country"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Country"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#is_located_in"/>
          <owl:someValuesFrom rdf:resource="#Europe"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#AsianCountry">
  <rdfs:subClassOf rdf:resource="#Country"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Country"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#is_located_in"/>
          <owl:someValuesFrom rdf:resource="#Asia"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#AbsMonarchyState">
  <rdfs:subClassOf rdf:resource="#Country"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Country"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_form_of_government"/>
          <owl:someValuesFrom rdf:resource="#Absolute_Monarchy"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#RepublicState">
  <rdfs:subClassOf rdf:resource="#Country"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Country"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_form_of_government"/>
          <owl:someValuesFrom>
            <owl:Class>
              <owl:oneOf rdf:parseType="Collection">
                <rdf:Description rdf:about="#Parliamentary_Republic"/>
                <rdf:Description rdf:about="#Federal_Republic"/>
              </owl:oneOf>
            </owl:Class>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#OrthodoxChristianCountry">
  <rdfs:subClassOf rdf:resource="#Country"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Country"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_main_religion"/>
          <owl:someValuesFrom rdf:resource="#Eastern_Orthodoxy"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#SunniIslamicCountry">
  <rdfs:subClassOf rdf:resource="#Country"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Country"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_main_religion"/>
          <owl:someValuesFrom rdf:resource="#Islam_Sunni"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#ShiaIslamicCountry">
  <rdfs:subClassOf rdf:resource="#Country"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Country"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_main_religion"/>
          <owl:someValuesFrom rdf:resource="#Islam_Shia"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#Megacity">
  <rdfs:subClassOf rdf:resource="#City"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#City"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#population"/>
          <owl:someValuesFrom>
            <rdfs:Datatype>
              <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
              <owl:withRestrictions>
                <rdf:Description>
                  <rdf:first>
                    <rdf:Description>
                      <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10000000</xsd:minInclusive>
                    </rdf:Description>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </owl:withRestrictions>
            </rdfs:Datatype>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#SmallVillage">
  <rdfs:subClassOf rdf:resource="#Village"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Village"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#population"/>
          <owl:someValuesFrom>
            <rdfs:Datatype>
              <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
              <owl:withRestrictions>
                <rdf:Description>
                  <rdf:first>
                    <rdf:Description>
                      <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">500</xsd:maxInclusive>
                    </rdf:Description>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </owl:withRestrictions>
            </rdfs:Datatype>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#HighPeak">
  <rdfs:subClassOf rdf:resource="#Peak"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Peak"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#height"/>
          <owl:someValuesFrom>
            <rdfs:Datatype>
              <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
              <owl:withRestrictions>
                <rdf:Description>
                  <rdf:first>
                    <rdf:Description>
                      <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8000.0</xsd:minInclusive>
                    </rdf:Description>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </owl:withRestrictions>
            </rdfs:Datatype>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#DeepWater">
  <rdfs:subClassOf rdf:resource="#WaterNaturalLocation"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#WaterNaturalLocation"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#depth"/>
          <owl:someValuesFrom>
            <rdfs:Datatype>
              <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
              <owl:withRestrictions>
                <rdf:Description>
                  <rdf:first>
                    <rdf:Description>
                      <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5000.0</xsd:minInclusive>
                    </rdf:Description>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </owl:withRestrictions>
            </rdfs:Datatype>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#TropicalIsland">
  <rdfs:subClassOf rdf:resource="#Island"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Island"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#is_island_in"/>
          <owl:someValuesFrom rdf:resource="#Ocean"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#temperature"/>
          <owl:someValuesFrom>
            <rdfs:Datatype>
              <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
              <owl:withRestrictions>
                <rdf:Description>
                  <rdf:first>
                    <rdf:Description>
                      <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">25.0</xsd:minInclusive>
                    </rdf:Description>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </owl:withRestrictions>
            </rdfs:Datatype>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#AncientBuilding">
